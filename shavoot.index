<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>    
    <meta charset="UTF-8">    
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">    
    <title>הורידי את חוברת שבועות | רבקה הולצברג</title>        
    
    <!-- פונטים ואייקונים -->    
    <link rel="preconnect" href="https://fonts.googleapis.com">    
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>    
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&display=swap" rel="stylesheet">    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>        
        :root {            
            --primary-green: #1B4D3E;            
            --accent-gold: #D4AF37;            
            --shavuot-pink: #C85A6C; /* הוורוד החגיגי של שבועות */
            --shavuot-pink-light: #fcf0f2;
            --text-dark: #222222;            
            --text-gray: #4A4A4A;        
        }

        /* הגדרות קריטיות למניעת חריגות רוחב ופס לבן בשמאל */        
        * {             
            margin: 0;             
            padding: 0;             
            box-sizing: border-box;         
        }

        html {            
            background-color: #ffffff;        
        }

        html, body {            
            max-width: 100%;            
            overflow-x: hidden;            
            position: relative;            
            margin: 0;            
            padding: 0;        
        }

        body {            
            font-family: 'Rubik', sans-serif;            
            color: var(--text-dark);            
            background-color: #ffffff;            
            display: flex;            
            flex-direction: column;            
            align-items: center;            
            justify-content: center;            
            min-height: 100vh;            
            padding: 20px 15px;            
            line-height: 1.6;            
            -webkit-font-smoothing: antialiased;        
        }

        .container {            
            width: 100%;            
            max-width: 500px;            
            position: relative;            
            z-index: 1;        
        }

        .glass-card {            
            background: #ffffff;            
            border-radius: 28px;            
            padding: 40px 30px;            
            box-shadow: 0 15px 45px rgba(27, 77, 62, 0.08);            
            border: 1px solid rgba(27, 77, 62, 0.06);            
            text-align: center;            
            animation: slideUp 0.6s ease-out;            
            width: 100%;        
        }

        .badge {            
            display: inline-flex;            
            align-items: center;            
            gap: 8px;            
            background: var(--shavuot-pink-light);            
            color: var(--shavuot-pink);            
            padding: 8px 18px;            
            border-radius: 50px;            
            font-size: 1rem;            
            font-weight: 600;            
            margin-bottom: 20px;        
        }

        h1 {            
            color: var(--primary-green);            
            font-size: 2.1rem;            
            font-weight: 700;            
            line-height: 1.2;            
            margin-bottom: 15px;            
            margin-top: 0;        
        }

        .subtitle {            
            color: var(--text-gray);            
            font-size: 1.25rem;            
            margin-bottom: 30px;        
        }

        /* עיצוב הטופס */        
        .form-group {            
            margin-bottom: 20px;            
            text-align: right;        
        }

        .form-group label {            
            display: block;            
            color: var(--primary-green);            
            font-weight: 600;            
            margin-bottom: 8px;            
            font-size: 1.1rem;            
            padding-right: 4px;        
        }

        input[type="email"] {            
            text-align: left;            
            direction: ltr;        
        }

        input[type="text"],        
        input[type="email"] {            
            width: 100%;            
            height: 52px;            
            padding: 0 16px;            
            border: 1px solid #DEDEDE;            
            border-radius: 12px;            
            font-family: 'Rubik', sans-serif;            
            font-size: 1.1rem;            
            background: #FAFAFA;            
            transition: all 0.3s ease;            
            color: var(--text-dark);        
        }

        input:focus {            
            outline: none;            
            border-color: var(--shavuot-pink);            
            background: #fff;            
            box-shadow: 0 4px 12px rgba(200, 90, 108, 0.08);        
        }

        /* כפתורי השלמה מהירה למייל */        
        .email-suggestions {            
            display: flex;            
            gap: 8px;            
            margin-top: 10px;            
            justify-content: flex-end;            
            flex-wrap: wrap;        
        }

        .domain-btn {            
            background: #F0F4F1;            
            color: var(--primary-green);            
            padding: 6px 12px;            
            border-radius: 50px;            
            font-size: 0.95rem;            
            cursor: pointer;            
            transition: all 0.2s ease;            
            border: 1px solid rgba(27, 77, 62, 0.1);            
            direction: ltr;            
            font-weight: 500;        
        }

        .domain-btn:hover {            
            background: var(--shavuot-pink-light);            
            border-color: var(--shavuot-pink);
            color: var(--shavuot-pink);
            transform: translateY(-1px);        
        }

        /* עיצוב תיבת האישור */        
        .checkbox-container {            
            background: #F8FAF9;            
            padding: 16px;            
            border-radius: 16px;            
            border: 1px solid #EDF2EF;            
            display: flex;            
            gap: 12px;            
            align-items: flex-start;            
            margin-bottom: 25px;            
            text-align: right;            
            cursor: pointer;            
            transition: all 0.2s;        
        }

        .checkbox-container:hover {            
            border-color: var(--shavuot-pink);        
        }

        .checkbox-container input {            
            width: 22px;            
            height: 22px;            
            accent-color: var(--primary-green);            
            cursor: pointer;            
            margin-top: 2px;            
            flex-shrink: 0;        
        }

        .checkbox-text {            
            font-size: 1.05rem;            
            color: var(--text-gray);            
            font-weight: 400;            
            line-height: 1.4;            
            margin: 0;            
            cursor: pointer;        
        }

        /* כפתור בוורוד שבועות */
        .submit-btn {            
            width: 100%;            
            height: 62px;            
            background: linear-gradient(135deg, #E58C9D 0%, #C85A6C 100%);            
            color: white;            
            border: none;            
            border-radius: 50px;            
            font-size: 1.35rem;            
            font-weight: 700;            
            cursor: pointer;            
            transition: all 0.3s ease;            
            box-shadow: 0 8px 25px rgba(200, 90, 108, 0.25);            
            display: flex;            
            align-items: center;            
            justify-content: center;            
            gap: 12px;            
            font-family: 'Rubik', sans-serif;        
        }

        .submit-btn:hover {            
            transform: translateY(-2px);            
            box-shadow: 0 12px 30px rgba(200, 90, 108, 0.35);        
        }

        .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

        @keyframes slideUp {             
            from { opacity: 0; transform: translateY(20px); }             
            to { opacity: 1; transform: translateY(0); }         
        }

        @media (max-width: 480px) {            
            .glass-card { padding: 30px 20px; border-radius: 20px; }            
            h1 { font-size: 1.7rem; }            
            .subtitle { font-size: 1.1rem; }            
            .submit-btn { font-size: 1.25rem; height: 56px; }        
        }    
    </style>
</head>
<body>
    <div class="container">        
        <div class="glass-card">                        
            <div class="badge">                
                <i class="fa-solid fa-wheat-awn"></i>                
                החוברת החגיגית לשבועות            
            </div>
            
            <h1>שבועות חגיגי ובריא</h1>                        
            <p class="subtitle">                
                המתכונים שיסגרו לך את שולחן החג.<br>                
                בלי גלוטן, בלי סוכר מוסף ובלי להתפשר על הטעם העשיר שאת אוהבת.            
            </p>
            
            <form id="signupForm">                                
                <div class="visually-hidden">                    
                    <label for="honeypot">נא להשאיר שדה זה ריק</label>                    
                    <input type="text" id="honeypot" name="honeypot" tabindex="-1">                
                </div>
                
                <!-- שיניתי את מקור הליד לשבועות -->
                <input type="hidden" name="lead_source" value="דף נחיתה שבועות - עיצוב נקי">
                
                <div class="form-group">                    
                    <label for="name">איך קוראים לך?</label>                    
                    <input type="text" id="name" name="name" required minlength="2">                
                </div>
                
                <div class="form-group">                    
                    <label for="email">כתובת המייל שלך</label>                    
                    <input type="email" id="email" name="email" required autocomplete="email">                    
                    <div class="email-suggestions" id="emailSuggestions">                        
                        <span class="domain-btn" data-domain="@gmail.com">@gmail.com</span>                        
                        <span class="domain-btn" data-domain="@walla.com">@walla.com</span>                    
                    </div>                
                </div>
                
                <label class="checkbox-container">                    
                    <input type="checkbox" id="marketing_consent" name="marketing_consent" required>                    
                    <span class="checkbox-text">                        
                        אני מאשרת לקבל מרבקה הולצברג מיילים הכוללים תוכן, טיפים, מתכונים והצעות שיווקיות למוצרים ותוכניות.<br>                        
                        <span style="font-size: 0.85em; opacity: 0.75;">ניתן להסיר בכל עת באמצעות קישור ההסרה שבמייל.</span>                    
                    </span>                
                </label>
                
                <button type="submit" class="submit-btn" id="submitBtn">                    
                    <span id="btnText">אני רוצה את החוברת לחג!</span>                    
                    <i class="fa-solid fa-gift"></i>                
                </button>            
            </form>        
        </div>    
    </div>

    <!-- סקריפט הפוטר שלך -->
    <script src="https://rivkaol.github.io/legal-footer.js"></script>
    
    <script>        
        // השלמה מהירה למייל        
        const emailInput = document.getElementById('email');        
        document.querySelectorAll('.domain-btn').forEach(btn => {            
            btn.addEventListener('click', function() {                
                const domain = this.getAttribute('data-domain');                
                let val = emailInput.value;                
                if (val.includes('@')) val = val.split('@')[0];                
                emailInput.value = val + domain;                
                emailInput.focus();            
            });        
        });

        document.getElementById('signupForm').addEventListener('submit', function(e) {            
            e.preventDefault();            
            if (document.getElementById('honeypot').value !== "") return;

            const btn = document.getElementById('submitBtn');            
            const btnText = document.getElementById('btnText');            
            btnText.innerText = "שולח...";            
            btn.disabled = true;

            const data = Object.fromEntries(new FormData(this).entries());            
            data.timestamp = new Date().toISOString();

            fetch('https://hook.eu2.make.com/lm31dmtx8enoyjhjufmqyv55wivnx4qx', {                
                method: 'POST',                
                headers: { 'Content-Type': 'application/json' },                
                body: JSON.stringify(data),            
            })            
            .then(res => {                
                if (res.ok) {                    
                    // שימי לב: העברתי את ההפניה לדף תודה ייעודי לשבועות במידה ותיצרי כזה. 
                    // אם אין דף כזה, אפשר לשנות חזרה ל- thanks-matok/thanks.html
                    window.location.href = 'https://rivkaholtsberg.co.il/thanks-matok/thanks.html';                
                } else {                    
                    alert("הייתה בעיה בשליחה, נסי שוב בעוד רגע.");                    
                    btnText.innerText = "אני רוצה את החוברת לחג!";                    
                    btn.disabled = false;                
                }            
            })            
            .catch(() => {                
                alert("הייתה בעיה בשליחה, נסי שוב בעוד רגע.");                
                btnText.innerText = "אני רוצה את החוברת לחג!";                
                btn.disabled = false;            
            });        
        });    
    </script>
</body>
</html>
